<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.secretvaul.controller.AddCredentialController"
      spacing="14" style="-fx-background-color: #F5F5F5; -fx-padding: 30;"
      prefWidth="380">
    <Label text="Nueva credencial"  style="-fx-text-fill: Black; -fx-font-size: 18; -fx-font-weight: bold;"/>

    <TextField fx:id="txtSitio" promptText="Sitio web (ej: github.com)"
               style="-fx-background-color: #FAFAFA; -fx-text-fill: black;
                      -fx-prompt-text-fill: #BDBDBD; -fx-padding: 10; -fx-background-radius: 6;"/>

    <TextField fx:id="txtCorreo" promptText="Correo o usuario"
               style="-fx-background-color: #FAFAFA; -fx-text-fill: black;
                      -fx-prompt-text-fill: #BDBDBD; -fx-padding: 10; -fx-background-radius: 6;"/>

    <PasswordField fx:id="txtPassword" promptText="Contraseña"
                   style="-fx-background-color: #FAFAFA; -fx-text-fill: black;
                          -fx-prompt-text-fill: #BDBDBD; -fx-padding: 10; -fx-background-radius: 6;"/>
    <TextField fx:id="txtNotas" promptText="Notas (opcional)"
               style="-fx-background-color: #FAFAFA; -fx-text-fill: black;
                      -fx-prompt-text-fill: #BDBDBD; -fx-padding: 10; -fx-background-radius: 6;"/>
    <Label fx:id="lblMensaje" text=""
           style="-fx-text-fill: #black; -fx-font-size: 11;"/>
    <HBox spacing="10">
        <Button text="Guardar" onAction="#handleGuardar"
                 maxWidth="Infinity"
                style="-fx-background-color: #1C1C1C; -fx-text-fill: white;
                       -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand;"/>
        <Button text="Cancelar" onAction="#handleCancelar"
                 maxWidth="Infinity"
                style="-fx-background-color: #1C1C1C; -fx-text-fill: white;
                       -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand;"/>
    </HBox>
</VBox>