<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.secretvaul.controller.GraficasController"
      spacing="16" styleClass="fondo-pantalla"
      prefWidth="700" prefHeight="500">

    <Label text="Estadísticas del baúl" styleClass="titulo-app"/>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <PieChart fx:id="pieChart" title="Credenciales por sitio"
                  HBox.hgrow="ALWAYS"/>
        <BarChart fx:id="barChart" title="Top sitios"
                  HBox.hgrow="ALWAYS">
            <xAxis><CategoryAxis label="Sitio"/></xAxis>
            <yAxis><NumberAxis label="Cantidad"/></yAxis>
        </BarChart>
    </HBox>

    <Button text="Cerrar" onAction="#handleCerrar"/>
</VBox>
