<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.secretvaul.controller.GraficasController"
      spacing="16" style="-fx-background-color: #f4f4f4; -fx-padding: 24;"
      prefWidth="700" prefHeight="500">

    <Label text="Estadísticas del baúl"
           style="-fx-font-size: 20; -fx-font-weight: bold;"/>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Pie chart: distribución por sitio -->
        <PieChart fx:id="pieChart" title="Credenciales por sitio"
                  HBox.hgrow="ALWAYS"/>

        <!-- Bar chart: cantidad por mes (o por dominio) -->
        <BarChart fx:id="barChart" title="Top sitios"
                  HBox.hgrow="ALWAYS">
            <xAxis>
                <CategoryAxis label="Sitio"/>
            </xAxis>
            <yAxis>
                <NumberAxis label="Cantidad"/>
            </yAxis>
        </BarChart>
    </HBox>

    <Button text="Cerrar" onAction="#handleCerrar"
            style="-fx-background-color: #1C1C1C; -fx-text-fill: white;
                   -fx-padding: 8 20; -fx-background-radius: 5;"/>
</VBox>